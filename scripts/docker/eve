#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR_DEFAULT="/opt/eve-docker"
CONFIG_FILE="/etc/eve-docker.conf"

if [ -f "$CONFIG_FILE" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG_FILE"
fi

INSTALL_DIR="${INSTALL_DIR:-$INSTALL_DIR_DEFAULT}"
COMPOSE_FILE="${COMPOSE_FILE:-$INSTALL_DIR/docker-compose.yml}"
ENV_FILE="${ENV_FILE:-$INSTALL_DIR/.env}"

need_cmd() {
    if ! command -v "$1" >/dev/null 2>&1; then
        echo "ERR: '$1' is required." >&2
        exit 1
    fi
}

write_caddyfile() {
    local ssl_mode="$1"
    local out_dir="$INSTALL_DIR/docker"
    mkdir -p "$out_dir"

    case "$ssl_mode" in
        letsencrypt)
            cat > "$out_dir/Caddyfile" <<'EOF'
{
    email {$LETSENCRYPT_EMAIL}
}

{$DOMAIN} {
    encode gzip zstd
    reverse_proxy app:5000
}
EOF
            ;;
        internal)
            cat > "$out_dir/Caddyfile" <<'EOF'
{
    email {$LETSENCRYPT_EMAIL}
}

{$DOMAIN} {
    tls internal
    encode gzip zstd
    reverse_proxy app:5000
}
EOF
            ;;
        http)
            cat > "$out_dir/Caddyfile" <<'EOF'
{
    auto_https off
}

http://{$DOMAIN} {
    encode gzip zstd
    reverse_proxy app:5000
}
EOF
            ;;
        *)
            echo "ERR: invalid SSL_MODE: $ssl_mode (use: letsencrypt | internal | http)" >&2
            exit 1
            ;;
    esac
}

read_env() {
    if [ ! -f "$ENV_FILE" ]; then
        return 0
    fi
    set -a
    # shellcheck disable=SC1090
    . "$ENV_FILE"
    set +a
}

set_env_kv() {
    local key="$1"
    local value="$2"

    mkdir -p "$(dirname "$ENV_FILE")"
    touch "$ENV_FILE"
    chmod 600 "$ENV_FILE" || true

    if grep -qE "^${key}=" "$ENV_FILE"; then
        # POSIX-safe replace
        tmp="$(mktemp)"
        awk -v k="$key" -v v="$value" 'BEGIN{FS=OFS="="} $1==k{$0=k"="v} {print}' "$ENV_FILE" > "$tmp"
        mv "$tmp" "$ENV_FILE"
    else
        echo "${key}=${value}" >> "$ENV_FILE"
    fi
}

compose() {
    docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE" "$@"
}

pause() { read -r -p "Press Enter..." _; }

print_header() {
    echo
    echo "==== $1 ===="
}

status() {
    print_header "Status"
    compose ps
}

logs() {
    print_header "Logs (app)"
    compose logs -n 200 app
}

restart_stack() {
    print_header "Restart"
    compose up -d
    echo "OK"
}

set_domain_and_ssl() {
    read_env

    print_header "Configure Domain + SSL"
    echo "Current DOMAIN: ${DOMAIN:-<unset>}"
    echo "Current SSL_MODE: ${SSL_MODE:-<unset>}"
    echo

    read -r -p "Domain or IP (example: panel.example.com): " new_domain
    new_domain="${new_domain:-${DOMAIN:-}}"
    if [ -z "$new_domain" ]; then
        echo "ERR: DOMAIN is required." >&2
        return 1
    fi

    read -r -p "SSL mode (http|internal|letsencrypt) [http]: " new_ssl
    new_ssl="${new_ssl:-${SSL_MODE:-http}}"

    # If user entered an IP, default to http to avoid ACME failures.
    if echo "$new_domain" | grep -Eq '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$' && [ "$new_ssl" = "letsencrypt" ]; then
        echo "WARN: DOMAIN looks like an IP; Let's Encrypt will likely fail. Switching SSL_MODE to http."
        new_ssl="http"
    fi

    read -r -p "Let's Encrypt email (optional) [${LETSENCRYPT_EMAIL:-admin@${new_domain}}]: " new_email
    new_email="${new_email:-${LETSENCRYPT_EMAIL:-admin@${new_domain}}}"

    set_env_kv "DOMAIN" "$new_domain"
    set_env_kv "SSL_MODE" "$new_ssl"
    set_env_kv "LETSENCRYPT_EMAIL" "$new_email"

    write_caddyfile "$new_ssl"

    echo "OK: updated .env and docker/Caddyfile"
    restart_stack
}

http_ip_quickstart() {
    print_header "HTTP-Only (IP) Quickstart"
    read -r -p "Server IP (example: 1.2.3.4): " ip
    if [ -z "$ip" ]; then
        echo "ERR: IP required." >&2
        return 1
    fi
    set_env_kv "DOMAIN" "$ip"
    set_env_kv "SSL_MODE" "http"
    set_env_kv "LETSENCRYPT_EMAIL" ""
    write_caddyfile "http"
    echo "OK: configured HTTP-only on ${ip}"
    restart_stack
    echo "Try: http://${ip}"
}

install_docker_from_bundle() {
    local deb_dir="$INSTALL_DIR/docker-debs"

    if [ ! -d "$deb_dir" ] || [ -z "$(ls -A "$deb_dir"/*.deb 2>/dev/null)" ]; then
        echo "ERR: docker-debs/ not found in $INSTALL_DIR." >&2
        echo "     This option requires the full offline bundle (eve-full-offline-bundle.tar.gz)." >&2
        echo "     Download it from the GitHub Releases page." >&2
        return 1
    fi

    echo "-- Installing Docker from bundled .deb packages"

    for pkg in containerd.io docker-ce-cli docker-ce docker-buildx-plugin docker-compose-plugin; do
        deb_file="$(ls "$deb_dir"/${pkg}_*.deb 2>/dev/null | head -1 || true)"
        [ -n "$deb_file" ] && dpkg -i --force-depends "$deb_file" 2>&1 || true
    done

    dpkg --configure -a 2>&1 || true
    systemctl enable docker 2>/dev/null || true
    systemctl start  docker 2>/dev/null || true

    if ! command -v docker >/dev/null 2>&1; then
        echo "ERR: Docker installation failed." >&2
        return 1
    fi

    echo "OK: $(docker --version)"
    echo "OK: $(docker compose version 2>/dev/null || echo 'compose plugin not detected')"
}

setup_full_offline() {
    if [ "${EUID}" -ne 0 ]; then
        echo "ERR: this option requires root: sudo eve" >&2
        return 1
    fi

    print_header "Setup Full Offline"
    echo "This installs Docker (if missing) and starts Eve from the local bundle."
    echo "No internet connection is required."
    echo

    if command -v docker >/dev/null 2>&1; then
        echo "Docker is already installed: $(docker --version)"
    else
        read -r -p "Docker is not installed. Install from bundled packages now? [Y/n]: " do_install
        do_install="${do_install:-Y}"
        if [ "$do_install" = "n" ] || [ "$do_install" = "N" ]; then
            echo "Skipped. Install Docker manually, then rerun."
            return 0
        fi
        install_docker_from_bundle || return 1
    fi

    if ! docker compose version >/dev/null 2>&1; then
        echo "ERR: Docker Compose plugin is not available." >&2
        return 1
    fi

    local images_tar="$INSTALL_DIR/docker-images.tar"
    if [ ! -f "$images_tar" ]; then
        echo "ERR: docker-images.tar not found in $INSTALL_DIR." >&2
        return 1
    fi

    echo "-- Loading Docker images (offline)"
    docker load -i "$images_tar"

    if [ ! -f "$ENV_FILE" ]; then
        set_domain_and_ssl
    else
        echo "-- Existing .env found"
        read -r -p "Reconfigure domain/SSL? [y/N]: " reconf
        if [ "${reconf:-N}" = "y" ] || [ "${reconf:-N}" = "Y" ]; then
            set_domain_and_ssl
        fi
    fi

    compose up -d

    echo
    echo "OK: Eve is running."
    echo "Use 'sudo eve' anytime to manage the stack."
}

main_menu() {
    if [ ! -f "$COMPOSE_FILE" ] && ! ls "$INSTALL_DIR"/docker-images.tar >/dev/null 2>&1; then
        echo "ERR: Installation files not found at: $INSTALL_DIR" >&2
        echo "Extract the bundle first, then run: sudo bash install.sh" >&2
        exit 1
    fi

    while true; do
        read_env
        echo
        echo "Eve Docker Manager"
        echo "Install dir : $INSTALL_DIR"
        echo "Domain      : ${DOMAIN:-<unset>}"
        echo "SSL mode    : ${SSL_MODE:-<unset>}"
        echo
        echo "[1] Status"
        echo "[2] Logs (app)"
        echo "[3] Set domain + SSL mode"
        echo "[4] Quickstart: IP without SSL (HTTP)"
        echo "[5] Restart stack"
        echo "[6] Setup Full Offline (install Docker + start Eve, no internet)"
        echo "[q] Quit"
        echo
        read -r -p "Select: " choice

        case "$choice" in
            1) need_cmd docker; status; pause ;;
            2) need_cmd docker; logs; pause ;;
            3) set_domain_and_ssl; pause ;;
            4) http_ip_quickstart; pause ;;
            5) need_cmd docker; restart_stack; pause ;;
            6) setup_full_offline; pause ;;
            q|Q) exit 0 ;;
            *) echo "Invalid choice" ;;
        esac
    done
}

main_menu

